# Los scripts que corren dentro del contenedor Linux DEBEN conservar saltos de
# línea LF. Con CRLF, el shebang se lee como "/bin/sh\r" y el contenedor falla
# con "bad interpreter". Esto lo fuerza sin importar el core.autocrlf del clon.
*.sh            text eol=lf
docker-entrypoint.sh text eol=lf
Dockerfile      text eol=lf
