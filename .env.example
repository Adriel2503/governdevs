# Copiar a .env para desarrollo local. En Dokploy estas variables se cargan desde
# la UI del panel (Environment). Todo lo centraliza app/config.py — no hay
# lectura de env vars sueltas en el código.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ OBLIGATORIAS EN PRODUCCIÓN: DATABASE_URL, CREDENTIALS_KEY,              │
# │ PUBLIC_BASE_URL, GRAPH_UI_PUBLIC_URL, WORKSPACE_DIR                     │
# └─────────────────────────────────────────────────────────────────────────┘


# ============================================================================
# BASE DE DATOS  (OBLIGATORIA)
# ============================================================================
# Postgres/ParadeDB. En Dokploy usá el HOST INTERNO de la base (el campo
# "Internal Host" del panel), NO la IP pública: la app y la base viven en la
# misma red de Docker y así no hace falta exponer ningún puerto.
DATABASE_URL=postgresql://postgres:TU_PASSWORD@personal-governdevsdb-xxxxx:5432/context_hub

# Para desarrollo local contra un ParadeDB en Docker:
# DATABASE_URL=postgresql://postgres:test@localhost:5433/context_hub


# ============================================================================
# CIFRADO DE SECRETOS  (OBLIGATORIA)
# ============================================================================
# Clave Fernet con la que se cifran los PAT y los secretos de webhook antes de
# guardarlos en Postgres. Vive SOLO en el entorno: si se filtra la base, no hay
# secretos en claro.
#
# Generar una (guardala, si la perdés no se pueden descifrar las credenciales):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_KEY=cambiame_por_una_clave_fernet_de_32_bytes_base64=


# ============================================================================
# URLS PÚBLICAS  (OBLIGATORIAS en producción)
# ============================================================================
# URL pública de la app. Con esto se arma la dirección del webhook que se
# registra automáticamente en GitHub. Si falta, el repo se registra igual pero
# SIN actualización automática.
PUBLIC_BASE_URL=https://governdevs.tu-dominio.com

# URL pública de la UI 3D del grafo (puerto 9749, dominio aparte en Dokploy).
# Sin esto, el botón "Ver grafo" redirige al localhost del navegador del usuario
# en vez del servidor.
GRAPH_UI_PUBLIC_URL=https://grafo.tu-dominio.com


# ============================================================================
# ALMACENAMIENTO  (OBLIGATORIA en producción)
# ============================================================================
# Los clones de los repos vigilados PERSISTEN (el reindexado incremental hace
# fetch sobre ellos y detect_changes necesita la historia). Tienen que caer
# dentro del volumen, o se pierden en cada redeploy y hay que re-clonar todo.
WORKSPACE_DIR=/app/data/workspace


# ============================================================================
# OPCIONALES
# ============================================================================
# Veredicto automático en los PR (cruza los cambios del grafo con los
# lineamientos). Sin esta clave la verificación igual corre y comenta los
# cambios, el impacto y las reglas aplicables — pero sin juicio automático.
# También habilita el endpoint REST /audit.
# ANTHROPIC_API_KEY=sk-ant-...

# Carpeta con los .md de lineamientos bundleados (se monta de solo lectura).
# WIKI_MICROSERVICIO_DIR=/app/wiki_data/Microservicio

# Tamaño máximo del ZIP de lineamientos que se acepta subir, en MB (default 500).
# La subida se escribe a disco por partes y del ZIP solo se extraen los .md, así
# que el consumo es constante: un export de wiki de 366 MB deja 2.9 MB en disco.
# Ojo: el proxy que tengas delante (Traefik en Dokploy) también tiene que tolerar
# subidas largas; este límite es el de la app, no el de la red.
# MAX_UPLOAD_MB=500

# Ruta al binario codebase-memory-mcp (motor de grafo).
# Default: se detecta según el SO (Windows local / Linux dentro del contenedor).
# CBM_BIN=/usr/local/bin/codebase-memory-mcp

# Puertos de la UI del grafo. En el contenedor cbm escucha en 9750 y Caddy
# publica el 9749 reescribiendo el Host.
# CBM_UI_PORT=9750
# CBM_UI_EXTERNAL_PORT=9749

# Timeouts de cbm en segundos. Indexar un repo grande tarda mucho más que una
# consulta puntual, por eso van separados.
# CBM_CLI_TIMEOUT=120
# CBM_INDEX_TIMEOUT=900
